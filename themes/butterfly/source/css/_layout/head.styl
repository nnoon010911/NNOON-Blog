#page-header
  position: relative
  width: 100%
  background-color: #eef4fb
  background-image: linear-gradient(180deg, #f3f7fd 0, #edf3fb 100%)
  background-position: center center
  background-size: cover
  background-repeat: no-repeat
  transition: all .5s

  if hexo-config('mask.header')
    &:not(.not-top-img):before
      position: absolute
      width: 100%
      height: 100%
      background-color: var(--mark-bg)
      content: ''

  // index
  &.full_page
    height: $index_top_img_height
    min-height: 320px
    background-attachment: scroll

    #site-info
      position: absolute
      top: $index_site_info_top
      left: 50%
      padding: 0 20px
      max-width: 780px
      width: 100%
      transform: translateX(-50%)

  #site-title,
  #site-subtitle,
  #scroll-down .scroll-down-effects
    text-align: center
    text-shadow: none
    line-height: 1.5

  #site-title
    margin: 0
    color: var(--font-color)
    font-size: 1.75em
    font-weight: 700
    @extend .limit-more-line
    -webkit-line-clamp: 3

    +minWidth768()
      font-size: 2.6em

  #site-subtitle
    margin-top: 12px
    color: var(--card-meta)
    font-size: 1.02em

    +minWidth768()
      font-size: 1.15em

  .site-intro-actions
    display: flex
    justify-content: center
    gap: 12px
    margin-top: 22px
    flex-wrap: wrap

    .site-intro-btn
      @extend .btn-effects
      display: inline-flex
      align-items: center
      justify-content: center
      min-width: 118px
      padding: 10px 16px
      border: 1px solid rgba(136, 152, 179, .22)
      background: rgba(255, 255, 255, .72)
      color: var(--font-color)
      font-size: .92rem
      font-weight: 600
      addBorderRadius(10)
      backdrop-filter: blur(10px)

      &:hover
        border-color: rgba(47, 111, 237, .26)
        background: rgba(255, 255, 255, .92)
        color: $theme-color

      &.primary
        border-color: rgba(47, 111, 237, .18)
        background: $theme-color
        color: var(--white)

        &:hover
          background: darken($theme-color, 8%)
          color: var(--white)

  #site_social_icons
    display: none
    margin: 0 auto
    text-align: center

    +maxWidth768()
      display: block

      .social-icon
        margin: 0 10px
        color: var(--card-meta)
        text-shadow: none
        font-size: 1.2em

  #scroll-down
    position: absolute
    bottom: -6px
    width: 100%
    cursor: pointer

    .scroll-down-effects
      position: relative
      width: 100%
      color: $theme-color
      font-size: 18px

  // page
  &.not-home-page
    height: 400px

    +maxWidth768()
      height: 280px

  #page-site-info
    position: absolute
    top: 200px
    padding: 0 10px
    width: 100%

    +maxWidth768()
      top: 140px

  // post
  &.post-bg
    height: 400px
    background-color: #eef4fb
    background-image: linear-gradient(180deg, #f3f7fd 0, #edf3fb 100%)

    +maxWidth768()
      height: 360px

    #nav
      #blog-info,
      a,
      span.site-page,
      .site-name
        color: var(--font-color)

    #post-info
      .post-title
        color: var(--font-color)

      #post-meta,
      #post-meta a
        color: var(--card-meta)

  #post-info
    position: absolute
    width: 100%

    if hexo-config('post_meta.post.position') == 'center'
      top: calc(50% + 30px)
      padding: 0 8%
      text-align: center
      transform: translateY(-50%)

      +maxWidth768()
        padding: 0 15px
    else
      bottom: 30px

      & > *
        margin: 0 auto
        padding: 0 15px
        max-width: 1200px

        @media screen and (min-width: 768px) and (max-width: 1300px)
          padding: 0 30px

        +minWidth2000()
          max-width: 70%

  &.not-top-img
    margin-bottom: 10px
    height: 60px
    background: 0

    .title-seo
      display: none

    #nav
      background: rgba(247, 250, 253, .88)
      border-bottom: 1px solid var(--light-grey)
      box-shadow: 0 10px 24px rgba(26, 44, 77, .06)

      a,
      span.site-page,
      .site-name
        color: var(--font-color)
        text-shadow: none

  &.nav-fixed
    #nav
      position: fixed
      top: -68px
      z-index: 91
      background: rgba(247, 250, 253, .88)
      border-bottom: 1px solid rgba(136, 152, 179, .16)
      box-shadow: 0 10px 24px rgba(26, 44, 77, .06)
      transition: transform .2s ease-in-out, opacity .2s ease-in-out
      will-change: transform
      backdrop-filter: blur(12px)

      #blog-info
        color: var(--font-color)

        &:hover
          color: $light-blue

        .site-name
          text-shadow: none

        & > a:first-child
          display: none

        & > a:last-child
          display: inline

      a,
      span.site-page,
      #toggle-menu
        color: var(--font-color)
        text-shadow: none

        &:hover
          color: $light-blue

    &.fixed
      #nav
        top: 0
        transition: all .5s

  &.nav-visible:not(.fixed)
    #nav
      transition: all .5s
      transform: translate3d(0, 100%, 0)

    & + .layout
      & > .aside-content > .sticky_layout
        top: 70px
        transition: top .5s

  &.fixed
    #nav
      position: fixed

    & + .layout
      & > .aside-content > .sticky_layout
        top: 70px
        transition: top .5s

      #card-toc
        .toc-content
          max-height: calc(100vh - 170px)

#page
  .page-title
    margin: 0 0 10px
    font-weight: bold
    font-size: 2em

// for not top_img
#post
  & > #post-info
    margin-bottom: 30px

    .post-title
      padding-bottom: 4px
      border-bottom: 1px solid var(--light-grey)
      color: var(--text-highlight-color)

      .post-edit-link
        float: right

    #post-meta,
    #post-meta a
      color: #78818a

#post-info
  .post-title
    @extend .limit-more-line
    margin-bottom: 8px
    color: var(--white)
    font-weight: normal
    font-size: 2.5em
    line-height: 1.5
    -webkit-line-clamp: 3

    +maxWidth768()
      font-size: 2.1em

    .post-edit-link
      padding-left: 10px

  #post-meta
    color: var(--light-grey)
    font-size: 95%

    +minWidth768()
      > .meta-secondline
        > span:first-child
          display: none

    +maxWidth768()
      font-size: 90%

      > .meta-firstline,
      > .meta-secondline
        display: inline

    .post-meta
      &-separator
        margin: 0 5px

      &-icon
        margin-right: 4px

      &-label
        if hexo-config('post_meta.post.label')
          margin-right: 4px
        else
          display: none

    a
      color: var(--light-grey)
      transition: all .3s ease-out

      &:hover
        color: $text-hover
        text-decoration: underline

    if hexo-config('post_meta.post.date_format') == 'relative'
      time
        display: none

#nav
  position: absolute
  top: 0
  z-index: 90
  display: flex
  align-items: center
  padding: 0 32px
  width: 100%
  height: 68px
  font-size: 1.1em
  opacity: 0
  transition: all .5s

  +maxWidth768()
    padding: 0 16px

  &.show
    opacity: 1

  #blog-info
    flex: 1
    color: var(--font-color)
    @extend .limit-one-line

    .site-icon
      margin-right: 6px
      height: 28px
      vertical-align: middle

    .nav-page-title
      display: none

  #toggle-menu
    display: none
    padding: 2px 0 0 6px
    vertical-align: top

    &:hover
      color: $theme-color

  a,
  span.site-page
    color: var(--font-color)

    &:hover
      color: $theme-color

  .site-name
    text-shadow: none
    font-weight: 700
    letter-spacing: .01em

  .menus_items
    display: inline

    .menus_item
      position: relative
      display: inline-block
      padding: 0 0 0 18px

      &:hover
        .menus_item_child
          display: block

        & > span > i:last-child
          transform: rotate(180deg)

      & > span > i:last-child
        padding: 4px
        transition: transform .3s

      .menus_item_child
        position: absolute
        right: 0
        display: none
        margin-top: 8px
        padding: 0
        width: max-content
        background-color: var(--sidebar-bg)
        border: 1px solid rgba(136, 152, 179, .16)
        box-shadow: 0 16px 32px rgba(26, 44, 77, .12)
        animation: sub_menus .3s .1s ease both
        addBorderRadius(5)

        &:before
          position: absolute
          top: -8px
          left: 0
          width: 100%
          height: 20px
          content: ''

        li
          list-style: none

          &:hover
            background: var(--text-bg-hover)

          if hexo-config('rounded_corners_ui')
            &:first-child
              border-top-left-radius: 5px
              border-top-right-radius: 5px

            &:last-child
              border-bottom-right-radius: 5px
              border-bottom-left-radius: 5px

          a
            display: inline-block
            padding: 8px 16px
            width: 100%
            color: var(--font-color) !important
            text-shadow: none !important

  &.hide-menu
    #toggle-menu
      display: inline-block !important

      .site-page
        font-size: inherit

    .menus_items
      display: none

    #search-button span:not(.site-page)
      display: none

  #search-button
    display: inline
    padding: 0 0 0 14px

  .site-page
    position: relative
    padding-bottom: 8px
    text-shadow: none
    font-size: .82em
    font-weight: 600
    cursor: pointer

    &:not(.child)
      &:after
        position: absolute
        bottom: 0
        left: 0
        z-index: -1
        width: 0
        height: 2px
        background-color: rgba(47, 111, 237, .28)
        content: ''
        transition: all .3s ease-in-out
        addBorderRadius()

      &:hover
        &:after
          width: 100%

  .nav-page-title
    position: relative
    overflow: hidden

    & > :first-child,
    & > :last-child
      display: inline-block
      transition: all .3s ease-in-out

    & > :last-child
      position: absolute
      top: 50%
      left: 0
      opacity: 0
      transform: translateY(-50%) translateY(-10px)

    &:hover
      & > :last-child
        opacity: 1
        transform: translateY(-50%) translateY(0)

      & > :first-child
        opacity: 0
        transform: translateY(10px)
